SERVER_PORT=8086

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/matching
SPRING_DATASOURCE_USERNAME=matching
SPRING_DATASOURCE_PASSWORD=changeme
# Usados por el postgres del docker-compose (deben coincidir con los de arriba)
POSTGRES_USER=matching
POSTGRES_PASS=changeme

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_SSL_ENABLED=false

SPRING_RABBITMQ_ADDRESSES=localhost:5673
SPRING_RABBITMQ_USERNAME=matching
SPRING_RABBITMQ_PASSWORD=changeme
RABBITMQ_VHOST=/
# Usados por el rabbitmq del docker-compose (deben coincidir con los de arriba)
RABBITMQ_USER=matching
RABBITMQ_PASS=changeme

INTERNAL_API_KEY=changeme-internal-key

# Debe ser el mismo valor que JWT_SECRET en auth-service y usuarios-service
JWT_SECRET=changeme-jwt-secret-must-be-at-least-32-chars

USUARIO_SERVICE_URL=http://localhost:8082
PARCHES_CORE_SERVICE_URL=http://localhost:8083

CORS_ALLOWED_ORIGINS=http://localhost:3000

MATCHING_MAX_POOL=200
MATCHING_TAMANO_COLA=50
MATCHING_SUGERENCIAS_TTL_HORAS=24
MATCHING_LIKES_TTL_DIAS=30
MATCHING_PARCHES_COMUN_HABILITADO=false
MATCHING_BONUS_POR_PARCHE=0.05

# mock-usuarios ya NO es necesario: usuarios-service (rama develop) tiene los endpoints.
# mock-parches sigue siendo necesario hasta que Parches Core agregue endpoint interno.
SPRING_PROFILES_ACTIVE=mock-parches
