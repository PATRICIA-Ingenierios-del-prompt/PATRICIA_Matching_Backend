SERVER_PORT=8086

POSTGRES_URL=jdbc:postgresql://localhost:5433/matching
POSTGRES_USER=matching
POSTGRES_PASS=changeme

REDIS_HOST=localhost
REDIS_PORT=6380

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USER=matching
RABBITMQ_PASS=changeme
RABBITMQ_VHOST=/

SECURITY_INTERNAL_API_KEY=changeme-internal-key
INTERNAL_API_KEY=changeme-internal-key

USUARIO_SERVICE_URL=http://localhost:8082
PARCHES_CORE_SERVICE_URL=http://localhost:8083

CORS_ALLOWED_ORIGINS=http://localhost:3000

MATCHING_MAX_POOL=200
MATCHING_TAMANO_COLA=50
MATCHING_SUGERENCIAS_TTL_HORAS=24
MATCHING_LIKES_TTL_DIAS=30
MATCHING_PARCHES_COMUN_HABILITADO=false
MATCHING_BONUS_POR_PARCHE=0.05

# Perfiles de desarrollo: HOY SON OBLIGATORIOS, no opcionales.
# Ni usuarios-service ni parches-core exponen aun los endpoints internos
# que Matching necesita (ver TODO_INTEGRACIONES.md). Sin estos perfiles
# activos, FeignPerfilUsuarioAdapter fallará en cada llamada.
SPRING_PROFILES_ACTIVE=mock-usuarios,mock-parches
